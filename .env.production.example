# ══════════════════════════════════════════════════════════════
# GESTOR DE LEADS API — PRODUCTION ENVIRONMENT
# Este arquivo deve ser renomeado para ".env" na VPS Hetzner
# ══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3333
HOST=0.0.0.0

# ══════════════════════════════════════════════════════════════
# BANCO DE DADOS (PostgreSQL + Redis)
# Ajustar IPs caso os bancos estejam no CCX13 e API no CPX31
# ══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres:SENHA_DO_BANCO@IP_DO_BANCO:5432/gestor_leads?schema=public"
REDIS_URL="redis://IP_DO_REDIS:6379"

# ══════════════════════════════════════════════════════════════
# SEGURANÇA / JWT
# Gere hashes seguros para produção!
# ══════════════════════════════════════════════════════════════
JWT_SECRET="SEU_HASH_MUITO_SEGURO_AQUI"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="SEU_OUTRO_HASH_MUITO_SEGURO_AQUI"
JWT_REFRESH_EXPIRES_IN="30d"

# ══════════════════════════════════════════════════════════════
# MINIO (STORAGE DE IMAGENS E ÁUDIOS)
# IMPORTANTE: MINIO_ENDPOINT deve ser acessível tanto 
# pelo Backend (Docker) quanto pelo Frontend (Browser dos acessos Web)
# Logo, é recomendado usar o IP Público ou Domínio (ex: api.midias.com)
# ══════════════════════════════════════════════════════════════
MINIO_ENDPOINT="157.180.45.175"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="midias-leads"
MINIO_USE_SSL=false

# ══════════════════════════════════════════════════════════════
# EVOLUTION API E WEBHOOKS
# API_BASE_URL é a URL ONDE O EVOLUTION MANDA AS MENSAGENS (Onde seu backend está rodando publicamente)
# EVO_URL é a URL ONDE O EVOLUTION ESTÁ ACESSÍVEL PARA O BACKEND ENTRAR EM CONTATO
# ══════════════════════════════════════════════════════════════
EVO_URL="https://apievo.wootzap.com.br"
EVO_KEY="d925d380f3e4f34d9c663817088da9b0"
API_BASE_URL="http://157.180.45.175:3333"
